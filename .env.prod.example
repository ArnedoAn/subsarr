SUBSYNC_REGISTRY=registry.example.com/your-namespace
SUBSYNC_API_IMAGE=subsync-api
SUBSYNC_WEB_IMAGE=subsync-web
SUBSYNC_TAG=latest

# File permissions
PUID=1000
PGID=1000

OPENROUTER_API_KEY=sk-or-...
DEEPSEEK_API_KEY=sk-...
SUBSYNC_MEDIA_VOLUME=/path/to/jellyfin/media
SUBSYNC_DATA_VOLUME=./data
SUBSYNC_MEDIA_DIRS=/media/movies,/media/series
SUBSYNC_SCAN_CACHE_TTL_MINUTES=30
SUBSYNC_SOURCE_LANGUAGE=eng
SUBSYNC_TARGET_LANGUAGE=spa
SUBSYNC_CONCURRENCY=2
SUBSYNC_PATH_EXCLUSIONS=/ignore/,/raw/
SUBSYNC_FILE_TOO_LARGE_BYTES=
NEXT_PUBLIC_API_URL=http://localhost:3001
